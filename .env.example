# iag-ai-platform service configuration.

ENVIRONMENT=development
SERVICE_NAME=ai-platform
PORT=3007
LOG_LEVEL=info

# Postgres (shares the platform instance; tables live in the `ai` schema).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/iag_platform?sslmode=disable
AUTO_MIGRATE=true

# Platform auth (Bearer + aud verification via iag-authentication JWKS).
AUTH_MODE=jwt
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
AUDIENCE=iag.ai-platform
SERVICE_CLIENT_ID=iag-ai-platform
# SERVICE_CLIENT_SECRET=        # required in production; minted by iag-authentication
# AUTH_TOKEN_URL=               # defaults to <JWT_ISSUER>/oauth/token

# Inference provider. Leave ANTHROPIC_API_KEY empty to use the deterministic
# stub provider (no external calls) — required to be set in production.
# ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_MAX_OUTPUT_TOKENS=1024
AI_EMBEDDING_DIM=256
